# Copy to .env and fill in your values

# --- LLM provider selection --------------------------------------------------
# Supported: ollama (default) | openrouter | langdock
LLM_PROVIDER=ollama

# Optional model override (overrides provider-specific defaults below)
# LLM_MODEL=

# --- Ollama (default, local, no API key required) ----------------------------
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=qwen2.5vl:3b
# Fallback list: comma-separated, tried in order when a model fails
# OLLAMA_MODELS=qwen2.5vl:3b,llama3.2:3b

# --- OpenRouter --------------------------------------------------------------
# OPENROUTER_API_KEY=
# Primary model (used if OPENROUTER_MODELS is not set)
# OPENROUTER_MODEL=meta-llama/llama-3.1-8b-instruct:free
# Fallback list: comma-separated, tried in order on rate-limit or empty response
# OPENROUTER_MODELS=meta-llama/llama-3.1-8b-instruct:free,google/gemma-3-27b-it:free

# --- LangDock ----------------------------------------------------------------
# LANGDOCK_API_KEY=
# LANGDOCK_API_URL=https://api.langdock.com/openai/v1
# LANGDOCK_MODEL=

# --- OCR language (Tesseract language code) ----------------------------------
OCR_LANG=deu

# Confidence threshold below which articles are flagged for review (0-100)
OCR_CONFIDENCE_THRESHOLD=70

# Set to "true" to start the inbox watcher automatically on container start
WATCH_INBOX=true

LOG_LEVEL=INFO
